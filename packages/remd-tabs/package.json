{
  "name": "@saeris/remd-tabs",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": "git@github.com:saeris/markdown.git",
  "files": [
    "dist"
  ],
  "type": "module",
  "style": "./dist/tabs.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./styles": {
      "development": "./src/tabs.css",
      "default": "./dist/tabs.css"
    }
  },
  "dependencies": {
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "unified": "^11.0.5"
  },
  "peerDependencies": {
    "unified": "^11.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bumpy": {
    "buildCommand": "vp pack && vp exec postcss src/tabs.css --output dist/tabs.css",
    "publishCommand": [
      "node ../../scripts/sync-jsr-version.mjs",
      "npm publish --access public",
      "npx jsr publish"
    ]
  }
}
