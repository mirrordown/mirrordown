{
  "name": "@mirrordown/remd-definition-list",
  "description": "A remark plugin for definition lists (term / : definition), rendering <dl>, <dt>, and <dd> elements.",
  "version": "0.1.3",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirrordown/mirrordown.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "dependencies": {
    "@types/hast": "catalog:",
    "mdast-util-from-markdown": "catalog:",
    "mdast-util-to-hast": "^13.0.0",
    "micromark-core-commonmark": "^2.0.0",
    "micromark-factory-space": "^2.0.0",
    "micromark-util-character": "catalog:",
    "micromark-util-chunked": "^2.0.0",
    "micromark-util-types": "catalog:",
    "unist-builder": "catalog:"
  },
  "devDependencies": {
    "unified": "catalog:"
  },
  "peerDependencies": {
    "unified": "^11.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bumpy": {
    "publishCommand": [
      "node ../../scripts/sync-jsr-version.mjs",
      "node ../../scripts/npm-publish.mjs",
      "node ../../scripts/jsr-resolve-deps.mjs",
      "node ../../scripts/jsr-publish.mjs"
    ]
  }
}
