{
  "name": "@mirrordown/remd-kbd",
  "description": "A remark plugin for keyboard key syntax ([[Ctrl]]), rendering <kbd> elements.",
  "version": "0.1.3",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirrordown/mirrordown.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "dependencies": {
    "unist-builder": "catalog:",
    "unist-util-find-after": "catalog:",
    "unist-util-find-all-after": "catalog:",
    "unist-util-find-all-before": "catalog:",
    "unist-util-find-between-all": "catalog:",
    "unist-util-visit": "catalog:"
  },
  "devDependencies": {
    "@types/mdast": "catalog:",
    "unified": "catalog:"
  },
  "peerDependencies": {
    "unified": "^11.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bumpy": {
    "publishCommand": [
      "node ../../scripts/sync-jsr-version.mjs",
      "node ../../scripts/npm-publish.mjs",
      "node ../../scripts/jsr-resolve-deps.mjs",
      "node ../../scripts/jsr-publish.mjs"
    ]
  }
}
