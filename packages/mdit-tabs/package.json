{
  "name": "@saeris/mdit-tabs",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": "git@github.com:saeris/markdown.git",
  "files": [
    "dist"
  ],
  "type": "module",
  "style": "./dist/tabs.css",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./styles": {
      "development": "./src/tabs.css",
      "default": "./dist/tabs.css"
    }
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "markdown-it": "^14.1.1"
  },
  "peerDependencies": {
    "markdown-it": "^14.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bumpy": {
    "buildCommand": "vp pack",
    "publishCommand": [
      "node ../../scripts/sync-jsr-version.mjs",
      "npm publish --access public",
      "npx jsr publish"
    ]
  }
}
