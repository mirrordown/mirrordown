{
  "name": "@mirrordown/mdit-tabs",
  "version": "0.1.1",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirrordown/mirrordown.git"
  },
  "style": "./dist/tabs.css",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./styles": {
      "development": "./src/tabs.css",
      "default": "./dist/tabs.css"
    }
  },
  "devDependencies": {
    "@types/markdown-it": "catalog:",
    "markdown-it": "catalog:"
  },
  "peerDependencies": {
    "markdown-it": "^14.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bumpy": {
    "buildCommand": "vp pack",
    "publishCommand": [
      "node ../../scripts/sync-jsr-version.mjs",
      "yarn pack -o package.tgz",
      "npm publish package.tgz --access public",
      "npx jsr publish --allow-dirty --allow-slow-types"
    ]
  }
}
