{
  "name": "@mirrordown/remd-inline-svg",
  "version": "0.1.2",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirrordown/mirrordown.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "dependencies": {
    "rehype-parse": "^9.0.1",
    "svgo": "catalog:"
  },
  "devDependencies": {
    "unified": "catalog:",
    "vfile": "^6.0.3"
  },
  "peerDependencies": {
    "unified": "^11.0.0",
    "vfile": "^6.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bumpy": {
    "buildCommand": "vp pack",
    "publishCommand": [
      "node ../../scripts/sync-jsr-version.mjs",
      "yarn pack -o package.tgz",
      "npm publish package.tgz --access public",
      "npx jsr publish --allow-dirty --allow-slow-types"
    ]
  }
}
