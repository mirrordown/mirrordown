{
  "name": "@mirrordown/mdit-lightbox",
  "description": "A markdown-it plugin to opt an image into a JavaScript-free <dialog> lightbox with a leading !! (zoom on click).",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirrordown/mirrordown.git"
  },
  "style": "./dist/lightbox.css",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./styles": {
      "development": "./src/lightbox.css",
      "default": "./dist/lightbox.css"
    }
  },
  "devDependencies": {
    "@types/markdown-it": "catalog:",
    "markdown-it": "catalog:"
  },
  "peerDependencies": {
    "markdown-it": "^14.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bumpy": {
    "publishCommand": [
      "node ../../scripts/sync-jsr-version.mjs",
      "node ../../scripts/npm-publish.mjs",
      "node ../../scripts/jsr-resolve-deps.mjs",
      "node ../../scripts/jsr-publish.mjs"
    ]
  }
}
