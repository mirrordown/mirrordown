# Whether you use PnP or not, the node_modules folder is often used to store
# build artifacts that should be gitignored
node_modules

# Swap the comments on the following lines if you wish to use zero-installs
# In that case, don't forget to run `yarn config set enableGlobalCache false`!
# Documentation here: https://yarnpkg.com/features/caching#zero-installs

# Yarn
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Editor
.DS_Store
.vscode/settings.json

# Claude — commit shared config (skills, commands); keep personal settings local
.claude/settings.local.json
superpowers/

# Debug / browser automation artifacts
.playwright-mcp/
.debug/

# Environment
.env
.env.local
.env.production 

# Visual-regression baselines are canonical on Linux (CI's platform). Ignore
# baselines/diffs generated on other OSes so a dev running the VRT locally on
# Windows/macOS doesn't commit platform-specific screenshots. Only *-linux.png
# is tracked.
tests/**/__screenshots__/**/*-win32.png
tests/**/__screenshots__/**/*-darwin.png
tests/**/__screenshots__/**/*.actual.png
tests/**/__screenshots__/**/*.diff.png

# Vitest browser-mode attachments (screenshot diffs from failed VRT runs)
.vitest-attachments/

# Outputs
**/dist/
.vite/
**/*.vsix
# Library pack artifact (created transiently during publish)
**/package.tgz
