{
  "$schema": "../node_modules/@varlock/bumpy/config-schema.json",
  "baseBranch": "main",
  "changelog": "default",
  "allowCustomCommands": true,
  "ignore": [
    "@saeris/markdown-docs",
    "markdown-abbr",
    "markdown-attrs",
    "markdown-definition-list",
    "markdown-del",
    "markdown-denden-furigana",
    "markdown-github-alerts",
    "markdown-inline-svg",
    "markdown-ins",
    "markdown-kbd",
    "markdown-mark",
    "markdown-preview-extended-syntax",
    "markdown-steps",
    "markdown-sub",
    "markdown-sup",
    "markdown-tabs",
    "markdown-unwrap-images"
  ]
}
