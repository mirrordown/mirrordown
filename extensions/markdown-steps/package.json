{
  "name": "markdown-steps",
  "displayName": "Markdown Steps",
  "version": "0.1.1",
  "description": "Adds steps syntax support to VSCode's markdown preview",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": "git@github.com:mirrordown/mirrordown.git",
  "publisher": "saeris",
  "main": "./dist/index.cjs",
  "browser": "./dist/index.cjs",
  "devDependencies": {
    "@mirrordown/mdit-steps": "workspace:*",
    "@types/markdown-it": "catalog:",
    "@types/vscode": "^1.125.0"
  },
  "contributes": {
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./dist/steps.css"
    ]
  },
  "activationEvents": [],
  "engines": {
    "vscode": "^1.125.0"
  },
  "bumpy": {
    "buildCommand": "vp pack && vp exec postcss src/steps.css --output dist/steps.css && vp exec vsce package --no-dependencies",
    "publishCommand": "vp exec vsce publish --no-dependencies",
    "skipNpmPublish": true
  }
}
