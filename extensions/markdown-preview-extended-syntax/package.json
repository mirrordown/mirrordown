{
  "name": "markdown-preview-extended-syntax",
  "displayName": "Markdown Preview Extended Syntax",
  "version": "0.1.3",
  "description": "A collection of syntax extensions for VSCode's Markdown Preview",
  "categories": [
    "Extension Packs",
    "Other"
  ],
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirrordown/mirrordown.git"
  },
  "publisher": "saeris",
  "extensionPack": [
    "Billaferd.vscode-header-sections",
    "saeris.markdown-abbr",
    "saeris.markdown-attributes",
    "saeris.markdown-autolink-headings",
    "saeris.markdown-definition-list",
    "saeris.markdown-del",
    "saeris.markdown-denden-furigana",
    "saeris.markdown-github-alerts",
    "saeris.markdown-inline-svg",
    "saeris.markdown-ins",
    "saeris.markdown-keyboard",
    "saeris.markdown-lightbox",
    "saeris.markdown-mark",
    "saeris.markdown-steps",
    "saeris.markdown-subscript",
    "saeris.markdown-superscript",
    "saeris.markdown-tabs",
    "saeris.markdown-unwrap-images"
  ],
  "engines": {
    "vscode": "^1.125.0"
  },
  "bumpy": {
    "buildCommand": "vp exec vsce package --no-dependencies",
    "publishCommand": "vp exec vsce publish --no-dependencies",
    "skipNpmPublish": true
  }
}
