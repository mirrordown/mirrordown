{
  "name": "markdown-autolink-headings",
  "displayName": "Markdown Heading Anchors",
  "version": "0.1.0",
  "description": "Adds shareable anchor links to headings in VSCode's markdown preview",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirrordown/mirrordown.git"
  },
  "publisher": "saeris",
  "main": "./dist/index.cjs",
  "browser": "./dist/index.cjs",
  "devDependencies": {
    "@mirrordown/mdit-autolink-headings": "workspace:*",
    "@mirrordown/mdit-slug": "workspace:*",
    "@types/markdown-it": "catalog:",
    "@types/vscode": "^1.125.0"
  },
  "contributes": {
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./dist/autolink-headings.css"
    ]
  },
  "activationEvents": [],
  "engines": {
    "vscode": "^1.125.0"
  },
  "bumpy": {
    "buildCommand": "vp pack && vp exec postcss src/autolink-headings.css --output dist/autolink-headings.css && vp exec vsce package --no-dependencies",
    "publishCommand": "vp exec vsce publish --no-dependencies",
    "skipNpmPublish": true
  }
}
