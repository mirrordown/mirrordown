{
  "name": "markdown-kbd",
  "displayName": "Markdown Keyboard <kbd>",
  "version": "0.0.0",
  "description": "Adds HTML Keyboard <kbd> support to VSCode's markdown preview",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": "git@github.com:saeris/markdown.git",
  "publisher": "saeris",
  "main": "./dist/index.cjs",
  "browser": "./dist/index.cjs",
  "devDependencies": {
    "@saeris/mdit-kbd": "workspace:*",
    "@types/markdown-it": "^14.1.2",
    "@types/vscode": "^1.118.0"
  },
  "contributes": {
    "markdown.markdownItPlugins": true
  },
  "activationEvents": [],
  "engines": {
    "vscode": "^1.118.0"
  },
  "bumpy": {
    "buildCommand": "vp pack && vp exec vsce package --no-dependencies",
    "publishCommand": "vp exec vsce publish",
    "skipNpmPublish": true
  }
}
