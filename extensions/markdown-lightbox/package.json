{
  "name": "markdown-lightbox",
  "displayName": "Markdown Image Lightbox",
  "version": "0.0.0",
  "description": "Adds a JavaScript-free click-to-zoom image lightbox to VSCode's markdown preview",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirrordown/mirrordown.git"
  },
  "publisher": "saeris",
  "main": "./dist/index.cjs",
  "browser": "./dist/index.cjs",
  "devDependencies": {
    "@mirrordown/mdit-lightbox": "workspace:*",
    "@types/markdown-it": "catalog:",
    "@types/vscode": "^1.125.0"
  },
  "contributes": {
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./dist/lightbox.css"
    ]
  },
  "activationEvents": [],
  "engines": {
    "vscode": "^1.125.0"
  },
  "bumpy": {
    "buildCommand": "vp pack && vp exec postcss src/lightbox.css --output dist/lightbox.css && vp exec vsce package --no-dependencies",
    "publishCommand": "vp exec vsce publish --no-dependencies",
    "skipNpmPublish": true
  }
}
