{
  "name": "markdown-tabs",
  "displayName": "Markdown Tabs",
  "version": "0.1.2",
  "description": "Adds tabs syntax support to VSCode's markdown preview",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mirrordown/mirrordown.git"
  },
  "publisher": "saeris",
  "main": "./dist/index.cjs",
  "browser": "./dist/index.cjs",
  "devDependencies": {
    "@mirrordown/mdit-tabs": "workspace:*",
    "@types/markdown-it": "catalog:",
    "@types/vscode": "^1.125.0"
  },
  "contributes": {
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./dist/tabs.css"
    ]
  },
  "activationEvents": [],
  "engines": {
    "vscode": "^1.125.0"
  },
  "bumpy": {
    "buildCommand": "vp pack && vp exec postcss src/tabs.css --output dist/tabs.css && vp exec vsce package --no-dependencies",
    "publishCommand": "vp exec vsce publish --no-dependencies",
    "skipNpmPublish": true
  }
}
