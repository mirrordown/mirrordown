{
  "name": "markdown-inline-svg",
  "displayName": "Markdown Inline SVG",
  "version": "0.1.1",
  "description": "Inline SVG images in VSCode's markdown preview",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.io> (https://saeris.gg)",
  "repository": "git@github.com:mirrordown/mirrordown.git",
  "publisher": "saeris",
  "main": "./dist/index.cjs",
  "browser": "./dist/index.cjs",
  "devDependencies": {
    "@types/vscode": "^1.125.0"
  },
  "contributes": {
    "markdown.previewScripts": [
      "./dist/preview.js"
    ]
  },
  "activationEvents": [],
  "engines": {
    "vscode": "^1.125.0"
  },
  "bumpy": {
    "buildCommand": "vp pack && vp exec vsce package --no-dependencies",
    "publishCommand": "vp exec vsce publish --no-dependencies",
    "skipNpmPublish": true
  }
}
