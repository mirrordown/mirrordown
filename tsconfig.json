{
  "include": ["./**/*.{j,t}s?(x)"],
  "exclude": ["node_modules", ".yarn", ".claude", "templates", "**/dist/**"],
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noErrorTruncation": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@saeris/*": ["./packages/*/src/index.ts"]
    }
  }
}
