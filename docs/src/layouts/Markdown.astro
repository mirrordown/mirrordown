---
import type { MarkdownHeading } from "astro";
import { getCollection } from "astro:content";
import Root from "./Root.astro";
import Sidebar from "../components/Sidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import "@saeris/remd-tabs/tabs.css";
import "@saeris/remd-github-alerts/github-alerts.css";
import "@saeris/remd-steps/steps.css";

interface Props {
  title: string;
  description?: string;
  headings: MarkdownHeading[];
}

const { title, description, headings } = Astro.props as Props;
const currentPath = new URL(Astro.request.url).pathname;

const entries = await getCollection("docs");

const groupMap = new Map<string, { label: string; href: string }[]>();
for (const entry of entries.sort((a, b) => a.id.localeCompare(b.id))) {
  const slash = entry.id.indexOf("/");
  const group = slash === -1 ? "" : entry.id.slice(0, slash);
  const items = groupMap.get(group) ?? [];
  items.push({ label: entry.data.title, href: `/${entry.id}` });
  groupMap.set(group, items);
}

const sidebarGroups = [...groupMap.entries()].map(([group, items]) => ({
  title: group.charAt(0).toUpperCase() + group.slice(1),
  items,
}));
---

<Root title={title} description={description}>
  <link slot="head" rel="stylesheet" href="/markdown.css" />
  <div class="app-shell">
    <aside class="app-sidebar">
      <Sidebar groups={sidebarGroups} currentPath={currentPath} />
    </aside>

    <main class="app-content">
      <article class="markdown-content">
        <slot />
      </article>
    </main>

    <aside class="app-toc">
      <TableOfContents headings={headings} />
    </aside>
  </div>
</Root>
