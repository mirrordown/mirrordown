<script>
  function syncAll() {
    const current = document.documentElement.getAttribute("data-theme") ?? "system";
    document.querySelectorAll<HTMLButtonElement>('button[data-theme-set]').forEach((btn) => {
      btn.dataset.active = String(btn.dataset.themeSet === current);
    });
  }

  function initThemeSwitchers() {
    document.querySelectorAll<HTMLElement>(".theme-switcher:not([data-init])").forEach((root) => {
      root.dataset.init = "true";
      root.querySelectorAll<HTMLButtonElement>('button[data-theme-set]').forEach((btn) => {
        btn.addEventListener("click", () => {
          document.dispatchEvent(new CustomEvent("set-theme", { detail: btn.dataset.themeSet }));
          syncAll();
        });
      });
    });
    syncAll();
  }

  initThemeSwitchers();
  document.addEventListener("astro:after-swap", () => {
    document.querySelectorAll<HTMLElement>(".theme-switcher").forEach((el) => {
      delete el.dataset.init;
    });
    initThemeSwitchers();
  });
</script>

<style>
  .theme-switcher {
    display: flex;
    align-items: center;
    gap: 0.5ch;
    padding: 0.1875rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
  }

  button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border: none;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--color-fg-muted);
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease;

    &:hover {
      color: var(--color-fg);
    }

    &[data-active="true"] {
      color: var(--color-fg);
      background-color: var(--color-border);
    }

    svg {
      display: block;
      width: 20px;
      height: 20px;
    }
  }
</style>

<div class="theme-switcher" role="group" aria-label="Color theme">
  <button data-theme-set="system" data-active="false" aria-label="System theme" aria-pressed="false">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="3" width="20" height="14" rx="2"/>
      <path d="M8 21h8M12 17v4"/>
    </svg>
  </button>
  <button data-theme-set="light" data-active="false" aria-label="Light theme" aria-pressed="false">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4"/>
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
    </svg>
  </button>
  <button data-theme-set="dark" data-active="false" aria-label="Dark theme" aria-pressed="false">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
</div>
