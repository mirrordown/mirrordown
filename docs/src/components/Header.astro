---
interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props as Props;
---

<style>
  header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 100;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-inline: 1.5rem;
    background-color: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: var(--fw-bold);
    font-size: var(--bl);
    color: var(--color-fg);
    flex-shrink: 0;

    span {
      color: var(--color-accent);
    }
  }

  nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
  }

  nav a {
    font-size: var(--lm);
    font-weight: var(--fw-medium);
    color: var(--color-fg-muted);
    padding: 0.375rem 0.625rem;
    border-radius: var(--radius-md);
    transition: color 0.15s ease, background-color 0.15s ease;

    &:hover {
      color: var(--color-fg);
      background-color: var(--color-border);
    }

    &[aria-current="page"] {
      color: var(--color-fg);
    }
  }

</style>

<header>
  <a class="logo" href="/">
    @saeris/<span>markdown</span>
  </a>

  <nav>
    <a href="/plugins/del" aria-current={currentPath.startsWith("/plugins") ? "page" : undefined}>
      Plugins
    </a>
  </nav>

</header>
