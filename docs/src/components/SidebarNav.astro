---
interface NavItem {
  label: string;
  href: string;
  root?: boolean;
}

interface NavCategory {
  title: string;
  items: NavItem[];
}

interface NavSection {
  title: string;
  rootHref?: string;
  categories: NavCategory[];
}

interface Props {
  sections: NavSection[];
  currentPath?: string;
}

const { sections, currentPath = "/" } = Astro.props as Props;
---

<style>
  nav {
    flex: 1;
    overflow-y: auto;
    padding-block: 1.25rem;
  }

  .section {
    & + & {
      border-top: 1px solid var(--color-border);
      margin-block-start: 0.75rem;
      padding-block-start: 0.75rem;
    }
  }

  details {
    margin-block-end: 0.25rem;
  }

  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--lt);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-fg-muted);
    padding: 0.25rem 1rem;
    border-radius: var(--radius-md);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: color 0.15s ease, background-color 0.15s ease;

    &::-webkit-details-marker { display: none; }
    outline: none;

    &:hover {
      color: var(--color-fg);
      background-color: var(--color-border);
    }

    &:focus-visible {
      outline: 2px solid var(--color-accent);
      outline-offset: -2px;
    }

    .chevron {
      display: block;
      width: 14px;
      height: 14px;
      flex-shrink: 0;
      color: var(--color-fg-subtle);
      transition: transform 0.2s ease;
    }
  }

  details[open] > summary .chevron {
    transform: rotate(180deg);
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding-inline: 0.5rem;
    margin-block-start: 0.25rem;
  }

  a {
    display: block;
    font-size: var(--lm);
    color: var(--color-fg-muted);
    padding: 0.3125rem 0.625rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: color 0.15s ease, background-color 0.15s ease;

    &:hover {
      color: var(--color-fg);
      background-color: var(--color-border);
    }

    &[aria-current="page"] {
      color: var(--color-accent);
      background-color: var(--color-accent-subtle);
      font-weight: 500;
    }
  }
</style>

<nav aria-label="Site navigation">
  {sections.map((section) => (
    <div class="section">
      {section.categories.map((cat) => {
        return cat.title ? (
          <details open>
            <summary>
              {cat.title}
              <svg class="chevron" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 6l4 4 4-4"/>
              </svg>
            </summary>
            <ul>
              {cat.items.map((item) => (
                <li>
                  <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ) : (
          <ul>
            {cat.items.map((item) => (
              <li>
                <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        );
      })}
    </div>
  ))}
</nav>
