---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props as Props;

const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{
  filtered.length > 0 && (
    <nav aria-label="On this page">
      <p class="toc-title">On this page</p>
      <ul>
        {filtered.map((heading) => (
          <li data-depth={heading.depth}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  nav {
    font-size: var(--text-xs);
  }

  .toc-title {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-fg-muted);
    margin-block-end: 0.5rem;
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  li[data-depth="3"] a {
    padding-inline-start: 1rem;
  }

  a {
    display: block;
    color: var(--color-fg-muted);
    padding-block: 0.1875rem;
    border-inline-start: 2px solid transparent;
    padding-inline-start: 0.5rem;
    transition: color 0.15s ease, border-color 0.15s ease;

    &:hover {
      color: var(--color-fg);
      border-inline-start-color: var(--color-border);
    }

    &.active {
      color: var(--color-accent);
      border-inline-start-color: var(--color-accent);
    }
  }
</style>

<script>
  const headingElements = document.querySelectorAll<HTMLElement>(
    ".markdown-content h2, .markdown-content h3",
  );

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        const id = entry.target.getAttribute("id");
        const link = document.querySelector<HTMLAnchorElement>(`.app-toc a[href="#${id}"]`);
        if (link) link.classList.toggle("active", entry.isIntersecting);
      }
    },
    { rootMargin: "-20% 0% -70% 0%" },
  );

  headingElements.forEach((el) => observer.observe(el));
</script>
