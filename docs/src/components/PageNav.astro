---
import { getCollection } from "astro:content";

interface Props {
  currentPath: string;
  lastModified?: string | null;
}

const { currentPath, lastModified } = Astro.props as Props;

const lastModifiedDate = lastModified ? new Date(lastModified) : null;
const lastModifiedDisplay = lastModifiedDate
  ? new Intl.DateTimeFormat("en-US", { month: "numeric", day: "numeric", year: "2-digit", hour: "numeric", minute: "2-digit" }).format(lastModifiedDate)
  : null;

const filePath = `docs/public${currentPath}.md`;
const editUrl = `https://github.com/saeris/markdown/edit/main/${filePath}`;
const devUrl = `https://github.dev/saeris/markdown/blob/main/${filePath}`;

const pages = (await getCollection("docs"))
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((entry) => ({ title: entry.data.title, href: `/${entry.id}` }));

const idx = pages.findIndex((p) => p.href === currentPath);
const prev = idx > 0 ? pages[idx - 1]! : null;
const next = idx < pages.length - 1 ? pages[idx + 1]! : null;
---

<div class="page-nav-wrapper">
  <div class="page-nav-meta">
    <span class="page-nav-edit">
      <a href={editUrl} data-dev-url={devUrl} target="_blank" rel="noopener noreferrer">Suggest changes to this page</a>
      <span class="page-nav-edit-hint">(Press <kbd>.</kbd> to edit in the browser)</span>
    </span>
    {lastModifiedDisplay && (
      <p class="page-nav-last-modified">
        Last modified: <time datetime={lastModified!}>{lastModifiedDisplay}</time>
      </p>
    )}
  </div>
  {(prev || next) && (
    <nav class="page-nav" aria-label="Page navigation">
      {prev ? (
        <a class="page-nav-link page-nav-prev" href={prev.href} rel="prev">
          <span class="page-nav-title">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {prev.title}
          </span>
          <span class="page-nav-footer">
            <span class="page-nav-direction">Previous</span>
            <span class="page-nav-kbd" aria-hidden="true">
              <kbd>shift</kbd><kbd>←</kbd>
            </span>
          </span>
        </a>
      ) : (
        <span />
      )}
      {next ? (
        <a class="page-nav-link page-nav-next" href={next.href} rel="next">
          <span class="page-nav-title">
            {next.title}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="page-nav-footer">
            <span class="page-nav-direction">Next</span>
            <span class="page-nav-kbd" aria-hidden="true">
              <kbd>shift</kbd><kbd>→</kbd>
            </span>
          </span>
        </a>
      ) : (
        <span />
      )}
    </nav>
  )}
</div>

<script>
  document.addEventListener("keydown", (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.code === "Period" && !e.shiftKey && !e.metaKey && !e.ctrlKey && !e.altKey) {
      const devUrl = document.querySelector<HTMLAnchorElement>(".page-nav-edit a")?.dataset.devUrl;
      if (devUrl) window.open(devUrl, "_blank", "noopener,noreferrer");
    } else if (e.shiftKey) {
      if (e.code === "ArrowLeft") {
        (document.querySelector<HTMLAnchorElement>("a.page-nav-prev"))?.click();
      } else if (e.code === "ArrowRight") {
        (document.querySelector<HTMLAnchorElement>("a.page-nav-next"))?.click();
      }
    }
  });
</script>

<style>
  .page-nav-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 2rem;
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
  }

  .page-nav-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 0 0 1rem;
    font-size: var(--lm);
    font-weight: var(--fw-regular);
    color: var(--color-fg-muted);
  }

  .page-nav-edit {
    display: flex;
    align-items: center;
    gap: 0.5rem;

    a {
      color: var(--color-fg-muted);
      text-decoration: underline;
      text-underline-offset: 2px;

      &:hover {
        color: var(--color-fg);
      }

      &:focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
        border-radius: var(--radius-sm);
      }
    }
  }

  .page-nav-edit-hint {
    color: var(--color-fg-muted);
  }

  .page-nav-last-modified {
    margin: 0;

    time {
      font-variant-numeric: tabular-nums;
    }
  }

  .page-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .page-nav-link {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-fg-muted);
    background-color: transparent;
    transition: border-color 0.15s, box-shadow 0.15s;

    &:hover {
      border-color: var(--color-accent);
      box-shadow: 0 0 0 1px var(--color-accent);
    }

    &:focus-visible {
      outline: 2px solid var(--color-accent);
      outline-offset: 2px;
    }
  }

  .page-nav-next {
    align-items: flex-end;
    text-align: right;
  }

  .page-nav-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--bl);
    font-weight: var(--fw-regular);
    color: var(--color-fg-muted);

    .page-nav-link:hover & {
      color: var(--color-fg);
    }

    svg {
      flex-shrink: 0;
    }
  }

  .page-nav-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;

    .page-nav-next & {
      justify-content: flex-end;
    }
  }

  .page-nav-direction {
    font-size: var(--lm);
    font-weight: var(--fw-regular);
    color: var(--color-fg-muted);
  }

  .page-nav-kbd {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .page-nav-kbd kbd,
  .page-nav-edit-hint kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.1em 0.375em;
    font-family: var(--family-mono);
    font-size: var(--lt);
    font-weight: var(--fw-semibold);
    color: var(--color-fg-muted);
    background-color: color-mix(in oklch, var(--color-accent) 4%, transparent);
    border: 1px solid color-mix(in oklch, var(--color-accent) 20%, var(--color-border));
    border-radius: var(--radius-sm);
    box-shadow: 0 2px 0 color-mix(in oklch, var(--color-accent) 20%, var(--color-border));
    line-height: 1.4;
  }
</style>
