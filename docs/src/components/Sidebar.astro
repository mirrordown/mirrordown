---
import ThemeSwitcher from "./ThemeSwitcher.astro";

interface NavItem {
  label: string;
  href: string;
}

interface NavGroup {
  title: string;
  items: NavItem[];
}

interface Props {
  groups: NavGroup[];
  currentPath?: string;
}

const { groups, currentPath = "/" } = Astro.props as Props;
---

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  nav {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem 0;
  }

  .group {
    margin-block-end: 1.5rem;
  }

  .group-title {
    font-size: var(--lt);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-fg-muted);
    padding-inline: 1rem;
    margin-block-end: 0.375rem;
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding-inline: 0.5rem;
  }

  a {
    display: block;
    font-size: var(--lm);
    color: var(--color-fg-muted);
    padding: 0.3125rem 0.625rem;
    border-radius: var(--radius-md);
    transition: color 0.15s ease, background-color 0.15s ease;

    &:hover {
      color: var(--color-fg);
      background-color: var(--color-border);
    }

    &[aria-current="page"] {
      color: var(--color-accent);
      background-color: light-dark(oklch(0.94 0.04 250), oklch(0.18 0.04 250));
      font-weight: 500;
    }
  }

  .sidebar-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--color-border);
  }

  .sidebar-socials {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: var(--radius-md);
    color: var(--color-fg-muted);
    transition: color 0.15s ease, background-color 0.15s ease;

    &:hover {
      color: var(--color-fg);
      background-color: var(--color-border);
    }

  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex-shrink: 0;

    svg {
      width: 100%;
      height: 100%;
    }
  }
</style>

<div class="sidebar">
  <nav aria-label="Sidebar navigation">
    {
      groups.map((group) => (
        <div class="group">
          <p class="group-title">{group.title}</p>
          <ul>
            {group.items.map((item) => (
              <li>
                <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-socials">
      <a
        class="social-link"
        href="https://github.com/saeris/markdown"
        aria-label="GitHub"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="social-icon">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </span>
      </a>
    </div>
    <ThemeSwitcher />
  </div>
</div>
